# evez-agentnet Environment Variables
# Copy to .env and fill in your values

# === REQUIRED ===
GITHUB_TOKEN=your_github_personal_access_token

# === AI PROVIDERS (at least one required) ===
ANTHROPIC_API_KEY=your_anthropic_key
GROQ_API_KEY=your_groq_key_for_fast_inference
OPENAI_API_KEY=your_openai_key_optional

# === INTEGRATIONS ===
ABLY_KEY=your_ably_key_for_realtime_events
SLACK_WEBHOOK_URL=your_slack_webhook_for_notifications
N8N_WEBHOOK_URL=your_n8n_webhook_for_automation_mesh

# === AGENT CONFIGURATION ===
REPO_OWNER=EvezArt
AGENT_NAME=cipher_trunk_v3
CYCLE_INTERVAL_HOURS=24
MAX_BRANCHES_PER_CYCLE=5
BRANCH_COOLDOWN_HOURS=6

# === MAES INTEGRATION ===
MAES_ENDPOINT=your_maes_server_endpoint
MAES_STREAM_ID=evez-agentnet

# === REVENUE SEEDS ===
CLAWHUB_API_KEY=your_clawhub_key
GUMROAD_API_KEY=your_gumroad_key

# === MONITORING ===
VERCEL_TOKEN=your_vercel_token_for_deploy_checks
AIRTABLE_API_KEY=your_airtable_key_for_registry
AIRTABLE_BASE_ID=your_airtable_base_id
