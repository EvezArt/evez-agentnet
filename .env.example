# EVEZ AgentNet — Terminal Surface .env
# Trunk-and-branch automation. All branches return to trunk.

LATENCY_THRESHOLD_MS=20
EVEZ_RPC_URL=
EXECUTION_MODE=TRUNK_BRANCH_AUTOMATION
RULE_2_REFUSAL_ENABLED=true
IDENTITY_ROOT_HASH=
SKEPTIC_ENTITY_PATH=./local/surething/skeptic_entity.py
N8N_WEBHOOK_URL=
BASE44_OPERATOR_ID=
LEDGER_SYNC_INTERVAL_MS=500
AUTO_BRANCH_RETURN=true
AUTO_SUMMARY_INTERVAL=4
PROVENANCE_LOGGING=STRICT
HUMAN_APPROVAL_MODE=BOUNDARY_ONLY

# AI providers (one required minimum)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
PERPLEXITY_API_KEY=

# External services
GITHUB_TOKEN=
VERCEL_TOKEN=
ABLY_KEY=
SLACK_WEBHOOK_URL=
TWITTER_BEARER_TOKEN=
GUMROAD_ACCESS_TOKEN=

# OpenClaw mesh
OPENCLAW_RECURSION_DEPTH=3
SPECULATIVE_EXECUTION_THREADS=4
TRUNK_SYNC_MODE=NON_BLOCKING
CAPTURE_THRESHOLD=0.01

# Surface roles
CLAUDE_ROLE=architect_refactorer
CHATGPT_ROLE=skeptic_verifier
PERPLEXITY_ROLE=recon_finder
BASE44_ROLE=executor_state_router
