{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExecutionIntegrity",
  "description": "Integrity envelope for an agentnet execution cycle.",
  "type": "object",
  "required": ["schema_version", "execution_id", "timestamp", "outcome", "checks"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "execution_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "outcome": { "type": "string", "enum": ["passed", "failed", "degraded", "replayed"] },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["passed", "failed", "skipped", "warning"] },
          "details": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "runtime": { "type": "string" },
    "transform_hash": { "type": "string" },
    "evidence_hash": { "type": "string" },
    "event_hash": { "type": "string" }
  },
  "additionalProperties": false
}