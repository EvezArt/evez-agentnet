{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContinuityStatus",
  "description": "Status artifact for compliance and continuity checkpoints.",
  "type": "object",
  "required": ["schema_version", "status_id", "timestamp", "state", "checked_files", "violations"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "status_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "state": { "type": "string", "enum": ["valid", "warning", "invalid", "pending"] },
    "checked_files": { "type": "integer", "minimum": 0 },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "reason"],
        "properties": {
          "path": { "type": "string" },
          "reason": { "type": "string" },
          "severity": { "type": "string", "enum": ["warning", "error"] }
        },
        "additionalProperties": false
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}