# evez-agentnet config -- copy to .env and fill in
GROQ_API_KEY=your_groq_key_here
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
PERPLEXITY_API_KEY=your_perplexity_api_key_here
GUMROAD_ACCESS_TOKEN=your_gumroad_token
GITHUB_TOKEN=your_github_token
EVEZ_OS_PATH=../evez-os
LOG_LEVEL=INFO
MAX_DRAFTS_PER_ROUND=3
MAX_SHIPS_PER_ROUND=2

# Sensor notes:
# GROQ_API_KEY       -- get from console.groq.com/keys (REQUIRED for predictor)
# TWITTER_BEARER_TOKEN -- get from developer.twitter.com (enables live tweet signals)
# PERPLEXITY_API_KEY -- get from perplexity.ai/settings/api (enables sonar intelligence)
# GITHUB_TOKEN       -- GitHub Actions $GITHUB_TOKEN is auto-injected (authenticated trending scan)
